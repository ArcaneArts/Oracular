<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap for ArcaneJasprApp.

  Replace https://example.com with your real domain. Add one <url>
  block for every page you want indexed. The <lastmod> date should
  be ISO-8601 (yyyy-MM-dd or full timestamp). Keep <priority>
  between 0.0 and 1.0 (1.0 = most important).

  Reference: https://www.sitemaps.org/protocol.html
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://example.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://example.com/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
</urlset>
